# Copy to .env for local dev (never commit .env — .gitignore excludes it).
# The Stripe key is deliberately ABSENT here: it lives only in 1Password and is
# resolved inline inside the Daytona sandbox at charge time (FR011/FR012).

# --- Orchestrator (Railway env in prod) ---
CHANNEL=mock                       # mock | whatsapp
OP_SERVICE_ACCOUNT_TOKEN=          # ops_...  bootstrap auth to 1Password
OP_VAULT=agent-identity            # vault holding owner records + the Stripe key
DAYTONA_API_KEY=                   # spawn/destroy sandboxes

# --- Manifest parser (Nebius Token Factory, OpenAI-compatible) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct   # confirm in Nebius model list

# --- WhatsApp (stretch) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886        # Twilio sandbox number

# --- Owner defaults applied at claim time ---
DEFAULT_BUDGET_CENTS=5000           # $50 task budget (matches the demo script)
DEFAULT_ALLOWLIST=Acme              # comma-separated vendor allowlist
